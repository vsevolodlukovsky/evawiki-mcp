{
  "mcpServers": {
    "evawiki": {
      "command": "evawiki-mcp",
      "env": {
        "EVAWIKI_API_URL": "https://eva.example.com/api/",
        "EVAWIKI_API_TOKEN": "YOUR_TOKEN_HERE",
        "EVAWIKI_VERIFY_SSL": "false"
      }
    },
    "evawiki-http": {
      "url": "http://localhost:8000/mcp"
    }
  }
}
